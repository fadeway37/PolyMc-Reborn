{
  "schemaVersion": 1,
  "id": "polymc-reborn",
  "version": "${version}",
  "name": "PolyMc Reborn",
  "description": "A conservative Polymer-backed compatibility platform for vanilla clients.",
  "authors": [
    "PolyMc Reborn contributors",
    "TheEpicBlock and original PolyMc contributors (upstream)"
  ],
  "contact": {
    "homepage": "https://github.com/fadeway37/PolyMc-Reborn",
    "issues": "https://github.com/fadeway37/PolyMc-Reborn/issues",
    "sources": "https://github.com/fadeway37/PolyMc-Reborn"
  },
  "license": "LGPL-3.0-or-later",
  "environment": "server",
  "provides": [
    "polymc"
  ],
  "entrypoints": {
    "main": [
      "io.github.polymcreborn.core.PolyMcReborn"
    ]
  },
  "mixins": [
    "polymc-reborn.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "=${minecraft_version}",
    "java": ">=25",
    "fabric-api": ">=${fabric_api_version}",
    "polymer-core": "=${polymer_version}",
    "polymer-blocks": "=${polymer_version}",
    "polymer-resource-pack": "=${polymer_version}",
    "polymer-virtual-entity": "=${polymer_version}",
    "polymer-registry-sync-manipulator": "=${polymer_version}"
  },
  "breaks": {
    "polymc-extra": "*"
  }
}
